{
  "name": "crashweaver",
  "version": "0.1.0",
  "private": true,
  "description": "Electron shell for the CrashWeaver AI-enhanced Obsidian knowledge app.",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.electron.json --watch",
    "dev:electron": "wait-on tcp:5173 dist-electron/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "test": "npm run test:electron && npm run test:renderer",
    "test:electron": "npm run build:main && node --test tests/electron/**/*.test.cjs",
    "test:renderer": "vitest run src/lib/markdownPreview.test.ts src/lib/editorPaths.test.ts src/lib/crashpadStatus.test.ts",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.electron.json",
    "build": "npm run typecheck && npm run build:renderer && npm run build:main",
    "start": "npm run build && electron ."
  },
  "dependencies": {
    "@types/diff": "^7.0.2",
    "@types/react-window": "^1.8.8",
    "chokidar": "^5.0.0",
    "diff": "^9.0.0",
    "katex": "^0.16.47",
    "markdown-it": "^14.1.1",
    "markdown-it-texmath": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-window": "^1.8.11",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.15.29",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.5.1",
    "jsdom": "^29.1.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.7",
    "wait-on": "^8.0.3"
  }
}
